# Airtable Personal Access Token (create at https://airtable.com/create/tokens)
# Requires scopes: data.records:read, data.records:write
AIRTABLE_API_TOKEN=
# Airtable Base ID (found in URL: https://airtable.com/appXXXXXXXXXXXXXX/...)
AIRTABLE_BASE_ID=
# Airtable Table Name (the tab name at the bottom of the base)
AIRTABLE_TABLE_NAME=contacts
